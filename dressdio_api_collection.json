        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/:email/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", ":email", "verify-email"],
              "variable": [
                {
                  "key": "email",
                  "value": "user@example.com",
                  "description": "Email address to verify"
                }
              ]
            },
            "description": "Check if user email exists in the system"
          }
        },
        {
          "name": "Send Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/:email/send-code?lang=en&template=register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", ":email", "send-code"],
              "query": [
                {
                  "key": "lang",
                  "value": "en",
                  "description": "Language code"
                },
                {
                  "key": "template",
                  "value": "register",
